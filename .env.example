GOOGLE_SHEET_ID=
GOOGLE_SHEET_NAME=Customers
GOOGLE_APPS_SCRIPT_URL=
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
NEXT_PUBLIC_ENABLE_NEW_STOCK_UI=true
REALTIME_BOOKING_PRICE_TTL_MINUTES=30
REALTIME_BOOKING_WEBHOOK_SECRET=
# Optional: comma/pipe separated subject keywords. Leave blank to accept any subject after sender/recipient filters.
REALTIME_BOOKING_GMAIL_SUBJECT=Pricing and Status Update
REALTIME_BOOKING_GMAIL_SENDER_DOMAIN=
REALTIME_BOOKING_GMAIL_RECIPIENT_CONTAINS=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_USER_EMAIL=me
GMAIL_OAUTH_REDIRECT_URI=
OPENAI_API_KEY=
OCR_OPENAI_MODEL=gpt-4o-mini

# Optional persistent local storage directory for Calendar / Leads / Vehicle Prep.
# Use a mounted persistent volume path on Railway/Render. Defaults to .data in the project.
BIG_CAR_DATA_DIR=

# Optional Supabase storage for Calendar / Leads / Vehicle Prep.
# 1) Run supabase/schema.sql in Supabase SQL Editor.
# 2) Set BIG_CAR_STORE_PROVIDER=supabase.
# 3) Keep SUPABASE_SERVICE_ROLE_KEY server-side only. Never expose it as NEXT_PUBLIC_*.
BIG_CAR_STORE_PROVIDER=json
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_CRM_STORE_TABLE=big_car_crm_store

# BIG CAR RDD public website (separate from CRM)
NEXT_PUBLIC_SITE_URL=https://bigcar-rdd.vercel.app
BIGCAR_SITE_SHEET_ID=
SITE_CONTACT_EMAIL=
SITE_ADMIN_EMAIL=
SITE_ADMIN_PASSWORD=
